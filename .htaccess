# FarmApp - Configuración Apache

# Habilitar rewrite engine
RewriteEngine On

# Base path (ajusta según tu instalación)
RewriteBase /farmapp/

# Permitir acceso directo a archivos estáticos en public/
RewriteCond %{REQUEST_URI} ^/farmapp/public/
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Permitir acceso directo a index.php en la raíz
RewriteCond %{REQUEST_URI} ^/farmapp/index\.php
RewriteRule ^ - [L]

# Proteger archivos sensibles
<FilesMatch "\.(sql|log|ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Configuración de PHP (compatible con InfinityFree)
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value max_input_time 300

